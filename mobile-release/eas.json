{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.example.com",
        "APP_IOS_BUNDLE_IDENTIFIER": "com.pavak01.weeklytaxapp.preview",
        "APP_ANDROID_PACKAGE": "com.pavak01.weeklytaxapp.preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.example.com",
        "APP_IOS_BUNDLE_IDENTIFIER": "com.pavak01.weeklytaxapp",
        "APP_ANDROID_PACKAGE": "com.pavak01.weeklytaxapp"
      }
    }
  },
  "submit": {
    "production": {}
  }
}